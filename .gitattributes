# Auto-detect text files and normalize line endings to LF
* text=auto eol=lf

# Explicitly mark script and config files as text with LF endings
*.ts text eol=lf
*.js text eol=lf
*.sh text eol=lf
*.md text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.html text eol=lf
*.css text eol=lf
*.vue text eol=lf

# Binary files (don't modify)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary

